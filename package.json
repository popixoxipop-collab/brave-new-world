{
  "name": "geowatch",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "dev:webpack": "next dev",
    "dev:clean": "node scripts/clean-next.js && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "gdelt:fetch": "node scripts/gdelt-fetch.js",
    "data:simplify": "node scripts/simplify-natural-earth.js",
    "data:build": "node scripts/build-local-data.js full",
    "data:build:lite": "node scripts/build-data-profile.js lite",
    "data:build:full": "node scripts/build-data-profile.js full",
    "data:build:all": "node scripts/build-data-profile.js lite && node scripts/build-data-profile.js full",
    "data:refresh": "npm run gdelt:fetch && npm run data:simplify && npm run data:build:full",
    "coastlines:build": "node scripts/build-coastlines.js full",
    "borders:build": "node scripts/build-country-borders.js full",
    "bri:build": "node scripts/build-bri-trade.js",
    "dfc:build": "node scripts/build-us-dfc-supply-chain.js",
    "static:build": "node scripts/build-static-extras.js full",
    "gem:build": "node scripts/build-gem-layers.js",
    "gem:build:lite": "node scripts/build-data-profile.js lite && node scripts/build-gem-layers.js",
    "gem:build:all": "node scripts/build-data-profile.js lite && node scripts/build-gem-layers.js && node scripts/build-data-profile.js full && node scripts/build-gem-layers.js",
    "sigint:fetch": "node scripts/fetch-sigint-layers.js",
    "sigint:convert": "node scripts/convert-sigint-layers.js",
    "sigint:build": "node scripts/fetch-sigint-layers.js && node scripts/convert-sigint-layers.js && node scripts/build-static-extras.js full",
    "data:sync": "node scripts/sync-live-data.js",
    "data:sync:force": "node scripts/sync-live-data.js --force",
    "data:sync:quick": "node scripts/sync-live-data.js --quick --force",
    "data:sync:full": "node scripts/sync-live-data.js --force --with-gdelt",
    "tensions:east-asia": "node scripts/merge-regional-tensions.js",
    "tensions:regional": "node scripts/merge-regional-tensions.js",
    "data:split-chunks": "node scripts/split-app-data-chunks.js all",
    "data:compress": "node scripts/compress-data-gzip.js all",
    "places:rebuild": "node scripts/rebuild-places.js full && node scripts/rebuild-places.js lite",
    "textures:fetch": "node scripts/fetch-textures.js",
    "palettes:extract": "node scripts/extract-map-palettes.js",
    "telegram:auth": "python scripts/telegram-osint/auth.py",
    "telegram:collect": "python scripts/telegram-osint/collector.py",
    "telegram:sync": "node scripts/telegram-sync.js",
    "tzeva-adom:poll": "node scripts/tzeva-adom/poller.js",
    "dev:live": "node scripts/dev-with-telegram.js",
    "viina:lfs": "node scripts/viina-lfs.js",
    "viina:build": "node scripts/build-viina-ukraine.js lite",
    "viina:build:full": "node scripts/build-viina-ukraine.js full",
    "ukraine:hatch:build": "tsx scripts/build-ukraine-hatch-cache.ts",
    "dispute:hatch:build": "tsx scripts/build-dispute-hatch-cache.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate:local": "wrangler d1 migrations apply conflict-view-db --local -c wrangler.ingest.toml",
    "db:migrate:remote": "wrangler d1 migrations apply conflict-view-db --remote -c wrangler.ingest.toml",
    "cf:ingest:dev": "wrangler dev -c wrangler.ingest.toml",
    "cf:ingest:deploy": "wrangler deploy -c wrangler.ingest.toml",
    "cf:ingest:tail": "wrangler tail -c wrangler.ingest.toml",
    "cf:d1:migrate:local": "npm run db:migrate:local",
    "cf:d1:migrate:remote": "npm run db:migrate:remote",
    "cf:app:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:app:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:app:upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf:r2:create": "wrangler r2 bucket create conflict-view-data",
    "cf:r2:upload": "node scripts/r2-upload-data.js",
    "cf:r2:upload:dry": "node scripts/r2-upload-data.js --dry-run",
    "cf:r2:upload:audio": "node scripts/r2-upload-data.js --audio-only",
    "cf:r2:upload:audio:dry": "node scripts/r2-upload-data.js --audio-only --dry-run",
    "axis:arms:build": "node scripts/build-axis-arms.js",
    "axis:vdem:build": "node scripts/build-axis-vdem.js",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@google/earthengine": "^1.7.34",
    "@streamparser/json": "^0.0.22",
    "adm-zip": "^0.5.18",
    "drizzle-orm": "^0.45.2",
    "fflate": "^0.8.3",
    "fuse.js": "^7.4.2",
    "iconv-lite": "^0.7.3",
    "maplibre-gl": "^5.24.0",
    "next": "14.2.35",
    "polygon-clipping": "^0.15.7",
    "react": "^18",
    "react-dom": "^18",
    "react-map-gl": "^8.1.1",
    "shapefile": "^0.6.6",
    "yahoo-finance2": "^3.15.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "@opennextjs/cloudflare": "1.15.1",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "mapshaper": "^0.7.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
