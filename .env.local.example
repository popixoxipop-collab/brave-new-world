# 서버 전용 — NEXT_PUBLIC_ 접두사를 붙이면 브라우저 번들에 노출됩니다.

# 외부 API stub (true=로컬 시드·가벼움, false=라이브 프록시)
# false 시 liveRenderGuard가 폴링 간격·FIRMS/AIS/ADS-B 상한을 자동으로 보수화합니다.
API_STUB_MODE=true

# 데이터 프로필: lite | full
DATA_PROFILE=lite

# R2 public CDN (정적 JSON + audio/) — 없으면 로컬 public/
# NEXT_PUBLIC_DATA_CDN=https://<your-r2-public-host>


# 레이어 플래그 (서버에서 판단, 클라이언트는 page.tsx 주입)
# NEPTUN_ENABLED=true
# TZEVA_ADOM_ENABLED=true
TELEGRAM_OSINT_ENABLED=true

# 데이터 동기화 폴링 간격(ms) — 선택
# SYNC_POLL_MS=300000

# API 키 (절대 NEXT_PUBLIC_ 금지)
# AISSTREAM_API_KEY=
# MarineTraffic / Kpler AIS (swagger exportvessels) — 지경학 민간 선박 보강
# MARINETRAFFIC_API_KEY=
# FIRMS_MAP_KEY=          # NASA FIRMS MAP_KEY (권장 이름)
# NASA_FIRMS_API_KEY=     # 동일 키 별칭 — 둘 중 하나만 있으면 됨
# ADSBexchange gateway 군용기 — header: x-api-key + Accept-Encoding: gzip
# ADSBEXCHANGE_API_KEY=
# ADSB_API_KEY=           # 별칭
# ADSBEXCHANGE_MIL_URL=   # 기본 https://gateway.adsbexchange.com/api/aircraft/v2/mil
# Freesound HQ mp3 프리뷰 (/api/sound-stream) — NEXT_PUBLIC_ 붙이지 말 것
# FREESOUND_API_KEY=

# Statistics of the World API Pro — 양피지 GDP·인구 카드 + /api/world-stats/*
# Docs: https://statisticsoftheworld.com/api-docs · Data bundle: https://statisticsoftheworld.com/data
# Header: X-API-Key (서버 전용, NEXT_PUBLIC_ 금지)
# STATSOFTHEWORLD_API_KEY=

# Anthropic Claude — 서버 편집/배치 digest 전용 (유저 「분석」은 BYOK, 이 키 미사용)
# ANTHROPIC_API_KEY=
# LLM_NEWS_DIGEST_ENABLED=false
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Telegram MTProto (my.telegram.org) — Python 수집기: npm run telegram:auth
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_PHONE=+8210xxxxxxxx
# TELEGRAM_USE_EMBED=true   # true=공개 embed(키 불필요), false 시에도 웹은 embed 가능·MTProto는 스크립트용

