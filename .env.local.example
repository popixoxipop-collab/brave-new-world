# API stub 모드 (기본 true) — 외부 API·sync·WebSocket 차단, 렌더 부하 최소화
API_STUB_MODE=true
NEXT_PUBLIC_API_STUB_MODE=true

# 실제 라이브 데이터 사용 시 false로 설정
# API_STUB_MODE=false
# NEXT_PUBLIC_API_STUB_MODE=false

# NASA FIRMS (서버 전용). MAP_KEY 있으면 /api/firms-fires 만 라이브 동작
FIRMS_MAP_KEY=


# Google Earth Engine (서비스 계정). 둘 중 하나만 사용하면 됩니다.
# 1) JSON 한 줄
# EE_PRIVATE_KEY_JSON={"client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}
# 2) 개별 변수
# EE_CLIENT_EMAIL=
# EE_PRIVATE_KEY=

# 정적 JSON 프로필: lite (노트북) | full (데모·고사양)
NEXT_PUBLIC_DATA_PROFILE=lite

# GEM 데이터 원본 (npm run gem:build). 기본: 프로젝트 기준 ../../../gem-data
# GEM_DATA_DIR=C:\Users\Administrator\Downloads\gem-data

# VIINA — 렌더링 전용 (ODbL). 공개 API/export 금지. docs/copyright-checklist.md 참고
VIINA_RENDERING_ONLY=true

# Telegram OSINT — 공개 embed 스크래핑 (기본, 로그인 불필요)
TELEGRAM_USE_EMBED=true
NEXT_PUBLIC_TELEGRAM_OSINT_ENABLED=true
# 속보·뉴스·Telegram 본문 자동 한국어 번역 (기본 켜짐). 끄려면 false
NEWS_TRANSLATE_KO=true
TELEGRAM_TRANSLATE_KO=true
# 데모 시드를 다시 쓰려면 TELEGRAM_USE_SEED=true

# Telethon 실시간 수집 (선택, TELEGRAM_USE_EMBED=false 일 때)
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_PHONE=+821012345678
# TELEGRAM_INGEST_SECRET=
# TELEGRAM_INGEST_URL=http://127.0.0.1:3000/api/telegram-alerts/ingest

# NEPTUN (우크라이나 공중 위협·경보) — NEXT_PUBLIC_NEPTUN_ENABLED=true 시 레이어 활성
# REST 폴링 ≤5초 · 실시간은 WebSocket (stub 모드에서는 시드 JSON)
# NEXT_PUBLIC_NEPTUN_ENABLED=true

# Tzeva Adom (이스라엘 Pikud HaOref 경보) — NEXT_PUBLIC_TZEVA_ADOM_ENABLED=true 시 레이어 활성
# 해외 IP: Oref-Alert-Proxy 등 프록시 URL 지정 (Java Tzeva-Adom-API 와 동일 History 엔드포인트)
# NEXT_PUBLIC_TZEVA_ADOM_ENABLED=true
# OREF_HISTORY_URL=https://www.oref.org.il/warningMessages/alert/History/AlertsHistory.json
# OREF_ACTIVE_URL=https://www.oref.org.il/WarningMessages/alert/alerts.json
# TZEVA_ADOM_POLL_MS=3000
